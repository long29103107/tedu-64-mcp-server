{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/order-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {CorrelationId} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId", "WithMachineName" ]
  },
  "SendGrid": {
    "ApiKey": "REPLACE_WITH_USER_SECRETS",
    "SenderEmail": "orders@tedu.com.vn",
    "SenderName": "TEDU Order System"
  },
  "Stripe": {
    "SecretKey": "REPLACE_WITH_USER_SECRETS",
    "WebhookSecret": "REPLACE_WITH_USER_SECRETS"
  },
  "Cache": {
    "ConnectionString": "localhost:6379",
    "DefaultExpiryMinutes": 30,
    "UseInMemory": false
  },
  "JwtSettings": {
    "SecretKey": "your-very-long-secret-key-min-32-chars",
    "Issuer": "OrderManagement.Api",
    "Audience": "OrderManagement.Client",
    "ExpiryMinutes": 60
  },
  "AllowedHosts": "*"
}
