meta {
  name: Place Order
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/orders
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "customerId": "{{customerId}}",
    "shippingAddress": {
      "street": "123 Nguyen Hue",
      "city": "Ho Chi Minh",
      "province": "HCM",
      "country": "VN",
      "postalCode": "70000"
    },
    "items": [
      {
        "productId": "{{productId}}",
        "quantity": 2
      }
    ]
  }
}
